# =============================================================
# SQL Trainer — environment variables
# =============================================================
# Alles is optioneel. Zonder env vars werkt de app 100% client-side.
# Vul deze enkel in als je Discord-logging wilt activeren.

# Discord webhook URL (server-side, NOOIT prefixen met NEXT_PUBLIC_)
# Server → Channel settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# Optioneel: vereist een geheim in X-Log-Secret header op /api/log
# (voorkomt dat random mensen je webhook spammen)
LOG_SECRET=
