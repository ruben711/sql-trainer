# =============================================================
# SQL Trainer — environment variables
# =============================================================
# Alles is optioneel. Zonder env vars werkt de basisapp 100% client-side.

# ─── Discord logging ────────────────────────────────────────
# Server → kanaal → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# Optioneel: vereist X-Log-Secret header op /api/log (anti-misbruik)
LOG_SECRET=

# ─── Leaderboard (Upstash Redis) ────────────────────────────
# Gratis tier: 10k commands/dag, 256MB.
# 1) Maak account op https://console.upstash.com
# 2) Create Database → Region: eu-west-1 (of dichtst bij Vercel)
# 3) Kopieer "UPSTASH_REDIS_REST_URL" en "UPSTASH_REDIS_REST_TOKEN"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternatief: Vercel KV (zelfde Upstash onder de motorkap)
# Vercel project → Storage → Create Database → KV
# Auto-injecteert KV_REST_API_URL en KV_REST_API_TOKEN — die worden ook gelezen.
