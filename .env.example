# Niets verplicht voor de basis-app: alles draait client-side.
# Onderstaande zijn enkel nodig als je later de OPTIONELE leaderboard / accounts inschakelt.

# Feature flags
NEXT_PUBLIC_ENABLE_LEADERBOARD=false

# Database (alleen indien leaderboard aan staat) — Vercel Postgres / Neon / Supabase URL
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# NextAuth (alleen indien accounts aan staan)
# NEXTAUTH_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
